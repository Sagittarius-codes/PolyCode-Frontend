# Local dev — used by `npm start` on http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api

# PolyGuard — rules in browser + Hugging Face ML model
REACT_APP_POLYGUARD_REMOTE_AUGMENT=true
REACT_APP_POLYGUARD_API_URL=https://muhammadsaadamin-polyguard-api.hf.space

# PolyMentor assistant is served by the Express backend at REACT_APP_API_URL (/api/chat/assistant).
# Set GROQ_API_KEY on the backend (see backend/.env.example).

# Production (Vercel frontend) — also set in Vercel → Settings → Environment Variables
# REACT_APP_API_URL=https://poly-code-backend.vercel.app/api